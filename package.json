{
  "name": "rockwell-order-processor",
  "version": "1.0.0",
  "description": "Order processing Lambda function — Rockwell Razors Technical Test",
  "main": "src/handler.ts",
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --verbose",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.500.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.130",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"],
    "setupFiles": ["<rootDir>/tests/jest.setup.ts"],
    "testTimeout": 20000
  }
}
